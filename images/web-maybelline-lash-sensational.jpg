    window.onload = (event) => {
        const closeBtn = document.getElementsByClassName("onetrust-close-btn-handler")[0];
        const skipToContent = document.getElementsByClassName("skip-to-content")[0];
        if(closeBtn){
            closeBtn.addEventListener("keypress", function(event) {
                if (event.key === "Enter") {
                    setTimeout(() =>  {
                            if(skipToContent){
                                skipToContent.focus();
                            }
                    }, 0);
                }
            });
        }
    };
</script>



    
    

    
